  "optimization": {
    "quantization": "quarot_w4a4kv4_gptq_weights",
    "optimization_brief": "Use QuaRot-style rotations so the LLaMA decode path can target W4A4KV4: 4-bit GPTQ weights, 4-bit rotated activations, and 4-bit KV-cache storage. The example assumes GPTQ weight tensors already exist and uses a local sparse metadata fixture only to exercise the parent planning flow.\n",
    "optimization_candidates": [
      {
        "name": "quarot_w4a4kv4",
        "scope": "primary example path",
        "notes": "rotate residual/attention/MLP streams, quantize activations to 4-bit, and store KV-cache in 4-bit form"
      },
      {
        "name": "w4a8kv4_fallback",
        "scope": "fallback",
        "notes": "keep weights and KV-cache at 4-bit but allow 8-bit activations if W4A4 timing or accuracy is unsafe"
      },
      {
        "name": "mixed_precision_softmax_control",
        "scope": "non_gemm_control",
        "notes": "keep softmax/control accumulations wider while preserving W4A4KV4 storage boundaries"
      }
    ],
    "optimization_extra_options": {
      "weight_quantization": {
        "method": "GPTQ",
        "bits": 4,
        "group_size": 128,
        "source_assumption": "implemented_checkpoint_available",
        "checkpoint_fixture": "sparse_header_and_payload_prefix_fixture"
      },
      "activation_quantization": {
        "bits": 4,
        "method": "QuaRot_rotated_activation_quantization",
        "calibration_source": "assumed_offline_quarot_calibration",
        "scale_granularity": "per_tensor_or_per_channel_to_be_selected_by_parent"
      },
      "kv_cache_quantization": {
        "bits": 4,
        "method": "QuaRot_KV4",
        "storage": "external_ddr_or_onchip_tile_cache",
        "dequant_location": "attention_score_value_path"
      },
      "rotation": {
        "method": "QuaRot",
        "transform": "hadamard_like_orthogonal_rotation",
        "placement": [
          "residual_stream_before_attention_projection",
          "qkv_projection_input",
          "attention_output_before_o_proj",
          "mlp_input_before_gate_up_projection",
          "kv_cache_write_read_boundary"
        ],
        "implementation_requirement": "rotation kernels must be separate non_gemm module packets unless fused by an explicit parent boundary review"
      },
      "numeric_policy": {
        "weight_bits": 4,
        "activation_bits": 4,
        "kv_cache_bits": 4,
        "accumulator_bits": 32,
        "requantization": "explicit_scale_shift_saturation"
      }
    },
    "weight_storage": "external_ddr_gptq_packed_stream_to_onchip_weight_stationary_tiles",
    "design_style": "systolic_weight_stationary_llm_streaming",
    "compute_style": "systolic_array",
    "execution_style": "llm_decoder_streaming",
    "memory_style": "external_ddr_streaming",
    "control_style": "hierarchical_fsm",
    "architecture_brief": "Use a weight-stationary systolic array for projection GEMM/GEMV tiles. GPTQ-packed W4 weights are streamed from DDR into on-chip tile buffers, unpacked/dequantized near the array edge, and reused in-place while rotated A4 activations stream through the array. Size the array from the active DSP budget rather than hardcoding a final dimension.\n",
    "design_candidates": [
      {
        "name": "ws_systolic_32x32",
        "focus": "first candidate under a 1536-DSP active compute budget",
        "risk": "routing pressure and activation/KV4 quantization overhead may reduce timing margin"
      },
      {
        "name": "ws_systolic_16x64",
        "focus": "preserve projection throughput while easing vertical routing",
        "risk": "less square data reuse and more edge buffering"
      },
      {
        "name": "ws_systolic_24x48",
        "focus": "middle-ground DSP use with easier BRAM banking",
        "risk": "tile scheduler is less regular than 32x32"
      }
    ],
    "design_extra_options": {
      "systolic_array": {
        "dataflow": "weight_stationary",
        "initial_rows": 32,
        "initial_cols": 32,
        "dsp_per_cell_assumption": 1,
        "active_dsp_budget": 1536,
        "reserved_dsp_for_non_gemm_and_control": 192,
        "sizing_rule": "choose rows*cols*dsp_per_cell <= active_dsp_budget after reserving non-GEMM/control DSP",
        "allowed_shapes": [
